<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_upwork_bid_stage_list" model="ir.ui.view">
        <field name="name">upwork.bid.stage.list</field>
        <field name="model">upwork.bid.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="fold"/>
                <field name="is_replied"/>
                <field name="is_moved_to_crm"/>
                <field name="is_no_response"/>
                <field name="is_won"/>
                <field name="is_lost"/>
            </list>
        </field>
    </record>

    <record id="view_upwork_bid_stage_form" model="ir.ui.view">
        <field name="name">upwork.bid.stage.form</field>
        <field name="model">upwork.bid.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="fold"/>
                        </group>
                        <group string="Stage Type Flags">
                            <field name="is_replied"/>
                            <field name="is_moved_to_crm"/>
                            <field name="is_no_response"/>
                            <field name="is_won"/>
                            <field name="is_lost"/>
                        </group>
                    </group>
                    <separator string="Description"/>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_upwork_bid_stage" model="ir.actions.act_window">
        <field name="name">Bid Stages</field>
        <field name="res_model">upwork.bid.stage</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
