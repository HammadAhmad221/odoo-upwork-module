<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_upwork_category_list" model="ir.ui.view">
        <field name="name">upwork.category.list</field>
        <field name="model">upwork.category</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="parent_id"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_upwork_category_form" model="ir.ui.view">
        <field name="name">upwork.category.form</field>
        <field name="model">upwork.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="color" widget="color_picker"/>
                        <field name="active"/>
                    </group>
                    <field name="child_ids">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="color" widget="color_picker"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_upwork_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">upwork.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
