<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_draft" model="upwork.bid.stage">
            <field name="name">Draft / To Bid</field>
            <field name="sequence">1</field>
        </record>
        <record id="stage_submitted" model="upwork.bid.stage">
            <field name="name">Submitted</field>
            <field name="sequence">10</field>
        </record>
        <record id="stage_viewed" model="upwork.bid.stage">
            <field name="name">Viewed by Client</field>
            <field name="sequence">20</field>
        </record>
        <record id="stage_replied" model="upwork.bid.stage">
            <field name="name">Client Replied</field>
            <field name="sequence">30</field>
            <field name="is_replied" eval="True"/>
        </record>
        <record id="stage_interview" model="upwork.bid.stage">
            <field name="name">Interview</field>
            <field name="sequence">40</field>
        </record>
        <record id="stage_moved_crm" model="upwork.bid.stage">
            <field name="name">Moved to CRM</field>
            <field name="sequence">50</field>
            <field name="fold" eval="True"/>
            <field name="is_moved_to_crm" eval="True"/>
        </record>
        <record id="stage_no_response" model="upwork.bid.stage">
            <field name="name">No Response</field>
            <field name="sequence">60</field>
            <field name="fold" eval="True"/>
            <field name="is_no_response" eval="True"/>
        </record>
        <record id="stage_won" model="upwork.bid.stage">
            <field name="name">Won</field>
            <field name="sequence">70</field>
            <field name="fold" eval="True"/>
            <field name="is_won" eval="True"/>
        </record>
        <record id="stage_lost" model="upwork.bid.stage">
            <field name="name">Lost</field>
            <field name="sequence">80</field>
            <field name="fold" eval="True"/>
            <field name="is_lost" eval="True"/>
        </record>
    </data>
</odoo>
