<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_upwork" model="ir.module.category">
            <field name="name">Upwork Bids</field>
            <field name="description">Manage access to the Upwork Bid Tracker</field>
            <field name="sequence">20</field>
        </record>

        <record id="upwork_groups_privilege" model="res.groups.privilege">
            <field name="name">Upwork Bids</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="module_category_upwork"/>
        </record>

        <record id="group_upwork_bidder" model="res.groups">
            <field name="name">Bidder</field>
            <field name="privilege_id" ref="upwork_groups_privilege"/>
            <field name="comment">Can create and edit own bids only.</field>
        </record>

        <record id="group_upwork_team_lead" model="res.groups">
            <field name="name">Team Lead</field>
            <field name="privilege_id" ref="upwork_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_upwork_bidder'))]"/>
            <field name="comment">Can see and edit all bids; manages templates and profiles.</field>
        </record>

        <record id="group_upwork_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="upwork_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('group_upwork_team_lead'))]"/>
            <field name="comment">Full access including reports and configuration.</field>
        </record>
    </data>
</odoo>
