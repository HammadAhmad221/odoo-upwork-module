<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_upwork_bid_own" model="ir.rule">
            <field name="name">Bidders: own bids only</field>
            <field name="model_id" ref="model_upwork_bid"/>
            <field name="groups" eval="[(4, ref('group_upwork_bidder'))]"/>
            <field name="domain_force">[('bidder_user_id','=',user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_upwork_bid_all" model="ir.rule">
            <field name="name">Team Leads: all bids</field>
            <field name="model_id" ref="model_upwork_bid"/>
            <field name="groups" eval="[(4, ref('group_upwork_team_lead'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
    </data>
</odoo>
